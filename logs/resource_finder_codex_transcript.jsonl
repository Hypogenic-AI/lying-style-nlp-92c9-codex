{"type":"item.started","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && pwd && python - << 'PY'\nimport arxiv, os, re\nfrom pathlib import Path\n\nids = [\n    '2403.09676',  # Unmasking the Shadows of AI\n    '2502.03407',  # Detecting Strategic Deception Using Linear Probes\n    '2507.22149',  # Truthful representations flip under deceptive instructions\n    '2405.12999',  # Model-On-Model Deception\n    '2307.08487',  # Latent Jailbreak\n    '2309.01446',  # Open Sesame\n    '2403.00867',  # Gradient Cuff\n    '2310.00905',  # All Languages Matter\n]\n\nPath('papers').mkdir(exist_ok=True)\nclient = arxiv.Client()\nsearch = arxiv.Search(id_list=ids)\nresults = list(client.results(search))\n\nmeta=[]\nfor r in results:\n    short = re.sub(r'[\"'^a-z0-9]+'\"','_', r.title.lower()).strip('_')[:55]\n    aid = r.get_short_id().split('v')[0]\n    fname = f\\\"{aid}_{short}.pdf\\\"\n    out = Path('papers')/fname\n    r.download_pdf(dirpath='papers', filename=fname)\n    meta.append({\n        'id': aid,\n        'title': r.title,\n        'authors': ', '.join(a.name for a in r.authors),\n        'year': r.published.year,\n        'pdf': str(out),\n        'url': r.entry_id,\n        'summary': r.summary.replace('\\\\n',' ').strip(),\n    })\n\nimport json\nwith open('papers/papers_metadata.json','w') as f:\n    json.dump(meta, f, indent=2)\n\nprint(f\\\"Downloaded {len(meta)} papers\\\")\nfor m in meta:\n    print(m['pdf'])\nPY\npwd && ls -la papers | sed -n '1,120p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
